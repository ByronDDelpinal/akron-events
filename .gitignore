# dependencies
node_modules
.pnp
.pnp.js

# build output
dist
dist-ssr

# Vite config cache — timestamped .mjs snapshots created during dev server startup
vite.config.js.timestamp-*

# env files — never commit real credentials
.env
.env.local
.env.*.local

# editor
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local docs — diagrams, exports, reference material
docs/

# local design explorations — mood boards, palette studies, etc.
design-proposals/

# vendored skill content — managed by skills-lock.json; re-sync locally
.agents/
.claude/skills/
