# dependencies
node_modules
.pnp
.pnp.js

# build output
dist
dist-verify
dist-check-*
dist-ssr

# Vite config cache — timestamped .mjs snapshots created during dev server startup
vite.config.js.timestamp-*

# env files — never commit real credentials
.env
.env.local
.env.*.local

# editor
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# raw / uncompressed video source files — only the compressed output belongs in the repo
public/video/*-source.*

# local docs — diagrams, exports, reference material
docs/

# local design explorations — mood boards, palette studies, etc.
design-proposals/

# vendored skill content — managed by skills-lock.json; re-sync locally
.agents/
.claude/skills/

# raw GIS source shapefiles — too large for git (Census TIGER files
# regularly exceed GitHub's 100 MB single-file limit). The conversion
# scripts in scripts/convert-*.js emit the compact GeoJSON we ship
# into public/, which IS committed.
data/gis/us_county_boundaries/
data/gis/ohio_places/
data/gis/ohio_county_subs/
