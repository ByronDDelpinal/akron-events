# Copy this file to .env and fill in your values.

# ── Supabase (Settings → API) ──────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase service role — server/scripts only, NEVER commit ──────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Eventbrite (restricted — search API not available for new keys) ─
EVENTBRITE_API_KEY=your-eventbrite-private-token-here

# ── Ticketmaster (developer.ticketmaster.com — free, instant) ──────
TICKETMASTER_API_KEY=your-ticketmaster-consumer-key-here
