# Copy this file to .env and fill in your values.

# ── Supabase (Settings → API) ──────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase service role — server/scripts only, NEVER commit ──────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Eventbrite (restricted — search API not available for new keys) ─
EVENTBRITE_API_KEY=your-eventbrite-private-token-here

# ── Ticketmaster (developer.ticketmaster.com — free, instant) ──────
TICKETMASTER_API_KEY=your-ticketmaster-consumer-key-here

# ── Mapbox (mapbox.com — geocoding only, free tier 100k requests/month) ──
# The frontend map renders with MapLibre + OpenFreeMap tiles (free, unlimited,
# no key needed). This token is used ONLY by scripts/geocode-venues.js to
# backfill venue coordinates. Get one at https://account.mapbox.com → Tokens.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token-here

# ── Google Analytics 4 (analytics.google.com) ───────────────────────
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
