# Copy this file to .env and fill in your values.

# ── Supabase (Settings → API) ──────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase service role — server/scripts only, NEVER commit ──────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Eventbrite (restricted — search API not available for new keys) ─
EVENTBRITE_API_KEY=your-eventbrite-private-token-here

# ── Ticketmaster (developer.ticketmaster.com — free, instant) ──────
TICKETMASTER_API_KEY=your-ticketmaster-consumer-key-here

# ── Mapbox (mapbox.com — free tier, 50k map loads/month) ────────────
# Get your token at https://account.mapbox.com → Tokens → Default public token
# This is a VITE_ prefix so it's bundled into the frontend build — this is safe
# for Mapbox public tokens (they're designed to be public and are scoped by URL).
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token-here
